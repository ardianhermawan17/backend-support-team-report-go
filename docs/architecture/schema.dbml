|- users -|

(id) [bigint] <> <PK, snowflake id>
(username) [varchar(64)] <> <active UNIQUE when deleted_at is null>
(email) [varchar(255)] <> <not blank>
(password_hash) [varchar(255)]
(created_at) [timestamptz]
(updated_at) [timestamptz]
(deleted_at) [timestamptz] <> <nullable, soft delete>

|- companies -|

(id) [bigint] <> <PK, snowflake id>
(user_id) [bigint] <> <FK -> users(id), active UNIQUE when deleted_at is null>
(name) [varchar(255)] <> <active UNIQUE when deleted_at is null>
(created_at) [timestamptz]
(updated_at) [timestamptz]
(deleted_at) [timestamptz] <> <nullable, soft delete>

|- images -|

(id) [bigint] <> <PK, snowflake id>
(imageable_id) [bigint]
(imageable_type) [varchar(50)]
(imageable identity) [imageable_type, imageable_id] <> <active UNIQUE when deleted_at is null>
(url) [text]
(mime_type) [varchar(100)]
(created_at) [timestamptz]
(updated_at) [timestamptz]
(deleted_at) [timestamptz] <> <nullable, soft delete>

|- teams -|

(id) [bigint] <> <PK, snowflake id>
(company_id) [bigint] <> <FK -> companies(id)>
(name) [varchar(255)] <> <active UNIQUE with company_id when deleted_at is null>
(logo_image_id) [bigint] <> <FK -> images(id), nullable, active UNIQUE when deleted_at is null>
(founded_year) [int]
(homebase_address) [text]
(city_of_homebase_address) [varchar(255)]
(created_at) [timestamptz]
(updated_at) [timestamptz]
(deleted_at) [timestamptz] <> <nullable, soft delete>

|- players -|

(id) [bigint] <> <PK, snowflake id>
(team_id) [bigint] <> <FK -> teams(id)>
(name) [varchar(255)]
(height) [numeric(5,2)]
(weight) [numeric(5,2)]
(position) [varchar(20)] <> <striker|midfielder|defender|goalkeeper>
(player_number) [int] <> <active UNIQUE with team_id when deleted_at is null>
(profile_image_id) [bigint] <> <FK -> images(id), nullable, active UNIQUE when deleted_at is null>
(created_at) [timestamptz]
(updated_at) [timestamptz]
(deleted_at) [timestamptz] <> <nullable, soft delete>

|- schedules -|

(id) [bigint] <> <PK, snowflake id>
(company_id) [bigint] <> <FK -> companies(id)>
(match_date) [date]
(match_time) [time]
(home_team_id) [bigint] <> <FK -> teams(id)>
(guest_team_id) [bigint] <> <FK -> teams(id)>
(match identity) [match_date, match_time, home_team_id, guest_team_id] <> <active UNIQUE when deleted_at is null>
(created_at) [timestamptz]
(updated_at) [timestamptz]
(deleted_at) [timestamptz] <> <nullable, soft delete>

|- reports -|

(id) [bigint] <> <PK, snowflake id>
(match_schedule_id) [bigint] <> <FK -> schedules(id), active UNIQUE when deleted_at is null>
(home_team_id) [bigint] <> <FK -> teams(id)>
(guest_team_id) [bigint] <> <FK -> teams(id)>
(final_score_home) [int]
(final_score_guest) [int]
(status_match) [varchar(20)] <> <home_team_win|guest_team_win|draw>
(most_scoring_goal_player_id) [bigint] <> <FK -> players(id), nullable>
(accumulate_total_win_for_home_team_from_start_to_the_current_match_schedule) [int]
(accumulate_total_win_for_guest_team_from_start_to_the_current_match_schedule) [int]
(created_at) [timestamptz]
(updated_at) [timestamptz]
(deleted_at) [timestamptz] <> <nullable, soft delete>

|- logs -|

(id) [bigint] <> <PK, snowflake id>
(actor_user_id) [bigint] <> <FK -> users(id), nullable>
(table_name) [varchar(100)]
(record_id) [bigint]
(action) [varchar(20)] <> <INSERT|UPDATE|SOFT_DELETE|RESTORE|DELETE>
(old_data) [jsonb]
(new_data) [jsonb]
(created_at) [timestamptz]
(deleted_at) [timestamptz] <> <nullable, soft delete>
